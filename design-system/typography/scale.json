{
  "fontFamilies": {
    "system": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif",
    "monospace": "'SF Mono', Monaco, 'Cascadia Code', 'Roboto Mono', Consolas, 'Courier New', monospace"
  },
  "typeScale": {
    "display": {
      "large": {
        "size": "57px",
        "lineHeight": "64px",
        "weight": "400",
        "letterSpacing": "-0.25px"
      },
      "medium": {
        "size": "45px",
        "lineHeight": "52px",
        "weight": "400",
        "letterSpacing": "0px"
      },
      "small": {
        "size": "36px",
        "lineHeight": "44px",
        "weight": "400",
        "letterSpacing": "0px"
      }
    },
    "headline": {
      "large": {
        "size": "32px",
        "lineHeight": "40px",
        "weight": "400",
        "letterSpacing": "0px"
      },
      "medium": {
        "size": "28px",
        "lineHeight": "36px",
        "weight": "400",
        "letterSpacing": "0px"
      },
      "small": {
        "size": "24px",
        "lineHeight": "32px",
        "weight": "400",
        "letterSpacing": "0px"
      }
    },
    "title": {
      "large": {
        "size": "22px",
        "lineHeight": "28px",
        "weight": "400",
        "letterSpacing": "0px"
      },
      "medium": {
        "size": "16px",
        "lineHeight": "24px",
        "weight": "500",
        "letterSpacing": "0.15px"
      },
      "small": {
        "size": "14px",
        "lineHeight": "20px",
        "weight": "500",
