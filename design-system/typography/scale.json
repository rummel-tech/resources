        "weight": "500",
        "letterSpacing": "0.1px"
      },
      "medium": {
        "size": "12px",
        "lineHeight": "16px",
        "weight": "500",
        "letterSpacing": "0.5px"
      },
      "small": {
        "size": "11px",
        "lineHeight": "16px",
        "weight": "500",
        "letterSpacing": "0.5px"
