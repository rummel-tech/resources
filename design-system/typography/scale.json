    "body": {
      "large": {
        "size": "16px",
        "lineHeight": "24px",
        "weight": "400",
        "letterSpacing": "0.5px"
      },
      "medium": {
        "size": "14px",
        "lineHeight": "20px",
        "weight": "400",
        "letterSpacing": "0.25px"
      },
      "small": {
        "size": "12px",
        "lineHeight": "16px",
        "weight": "400",
        "letterSpacing": "0.4px"
